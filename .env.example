# =============================================================================
# Ticket Tracker — environment configuration (EXAMPLE / TEMPLATE)
# =============================================================================
# Copy this file to `.env` and adjust the values for your machine:
#
#     cp .env.example .env        (Linux/macOS)
#     Copy-Item .env.example .env (Windows PowerShell)
#
# `.env` is gitignored and holds the REAL values (incl. secrets). This file
# (`.env.example`) is committed and documents every variable with safe local
# defaults. NEVER commit real secrets (DB passwords, SMTP credentials, token
# secret) — see REQUIREMENTS_SOURCE §11 and ARCHITECTURE §8.
#
# `docker compose` loads this file via `env_file: .env` for every service.
# Variable names match ARCHITECTURE.md §8 exactly (ASP.NET Core reads the
# `__`-delimited keys such as ConnectionStrings__Default natively).
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL (consumed by the `db` container and by the `api` connection string)
# -----------------------------------------------------------------------------
# DB user, password and database name used to bootstrap the postgres container.
# The api's ConnectionStrings__Default below must use these same credentials.
# The password is for LOCAL DEV ONLY — set a real secret in production.
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=change-me-local
POSTGRES_DB=ticketing


# -----------------------------------------------------------------------------
# Database connection (consumed by `api` — EF Core / Npgsql)
# -----------------------------------------------------------------------------
# ASP.NET Core maps ConnectionStrings__Default -> ConnectionStrings:Default.
# Host is the compose service name `db`; port 5432 is the in-network port
# (NOT published to the host). Keep Username/Password/Database in sync with the
# POSTGRES_* values above.
ConnectionStrings__Default=Host=db;Port=5432;Database=ticketing;Username=ticketing;Password=change-me-local


# -----------------------------------------------------------------------------
# Authentication / session tokens (consumed by `api` — ADR-0001)
# -----------------------------------------------------------------------------
# Secret used as the HMAC pepper for the opaque-bearer-token model. Generate a
# strong random value before any real use, e.g.:
#     openssl rand -base64 48
# Leave the placeholder for throwaway local runs only — DO NOT ship it.
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret

# Session (bearer) token lifetime in hours (ADR-0001). After this the token
# expires and the user must log in again.
SESSION_TTL_HOURS=72

# Email-verification token lifetime in hours. Source §3 mandates 24h, single-use.
TOKEN_TTL_HOURS=24

# Password-reset token lifetime in hours (F-01, ADR-0010). Single-use; deliberately
# shorter than the verification TTL — a reset link is higher-value and should live briefly.
PASSWORD_RESET_TTL_HOURS=1


# -----------------------------------------------------------------------------
# SMTP / email verification (consumed by `api` — ADR-0004, source §3)
# -----------------------------------------------------------------------------
# The verification email is sent through this relay. The implementation MUST
# support relay1.dataart.com (source §3). For local manual QA you may point
# SMTP_HOST at a local mail catcher (e.g. MailDev/Mailpit) instead.
SMTP_HOST=relay1.dataart.com

# SMTP port. 587 = submission with STARTTLS (recommended); 25 = plain relay.
SMTP_PORT=587

# SMTP auth credentials. The relay may be unauthenticated on the internal
# network, in which case leave BOTH blank. Fill them in only if your relay
# requires auth. NEVER commit real credentials.
SMTP_USERNAME=
SMTP_PASSWORD=

# Upgrade the connection to TLS via STARTTLS (true for port 587). Set to false
# only for a local plaintext catcher.
SMTP_USE_STARTTLS=true

# The From: header on outgoing verification emails.
EMAIL_FROM=no-reply@ticketing.local


# -----------------------------------------------------------------------------
# Frontend / verification links (consumed by `api`)
# -----------------------------------------------------------------------------
# Base URL the SPA is reachable at. The api builds verification links as
# ${FRONTEND_URL}/verify-email?token=<token>, so QA's emailed links resolve to
# a working address. Matches the single entry point http://localhost:8080.
FRONTEND_URL=http://localhost:8080


# -----------------------------------------------------------------------------
# User management — default signup team (consumed by `api` — ADR-0007/0008)
# -----------------------------------------------------------------------------
# Team a self-registered user joins automatically AFTER verifying their email
# (req 8). Matched case-insensitively by name. If no team with this name exists,
# it is AUTO-CREATED at first self-signup verification, race-safely (F-10, ADR-0011,
# supersedes the ADR-0008 warn-and-skip clause). The migration still auto-creates
# nothing (ADR-0003: a fresh DB has schema only) — creation is lazy runtime logic.
# Leave BLANK to disable auto-join/auto-create (verify then logs a warning and skips).
DEFAULT_SIGNUP_TEAM_NAME=Demo Team


# -----------------------------------------------------------------------------
# Migrations (consumed by `api` — ADR-0003)
# -----------------------------------------------------------------------------
# When true (default), the api applies all pending EF Core migrations on
# startup. No seed/sample data is ever inserted (source §9/§13: a fresh DB has
# schema + migration metadata only). Set false only if you apply migrations
# out-of-band.
RUN_MIGRATIONS_ON_STARTUP=true


# -----------------------------------------------------------------------------
# Notification email outbox (consumed by `api` — Wave 2, ADR-0014)
# -----------------------------------------------------------------------------
# In-app notifications are instant; email is coalesced by a background worker.
# NOTIFICATION_EMAIL_DEBOUNCE_SECONDS is the minimum age a notification must
# reach before it is emailed, so a rapid burst to one recipient collapses into a
# single digest. NOTIFICATION_WORKER_POLL_SECONDS is how often the worker drains
# the outbox (email latency is bounded by debounce + poll, ~75s by default).
# Set NOTIFICATIONS_EMAIL_ENABLED=false to disable the worker entirely (in-app
# notifications keep working) — a clean kill-switch if SMTP is down.
NOTIFICATION_WORKER_POLL_SECONDS=15
NOTIFICATION_EMAIL_DEBOUNCE_SECONDS=60
NOTIFICATIONS_EMAIL_ENABLED=true


# -----------------------------------------------------------------------------
# Attachments (consumed by `api` — Wave 3, ADR-0018)
# -----------------------------------------------------------------------------
# File attachments on tickets are stored as blobs on a local Docker named volume
# (`attachments:` in docker-compose.yml) mounted into the api container at
# ATTACHMENTS_ROOT; only metadata lives in the DB. The api creates the directory
# on startup if missing. ATTACHMENTS_MAX_BYTES is the per-file size cap enforced
# while streaming (over-cap → 413). Keep nginx `client_max_body_size` (12m) above
# this value + multipart overhead (frontend/nginx.conf, §9.1).
ATTACHMENTS_ROOT=/var/lib/tickettracker/attachments
ATTACHMENTS_MAX_BYTES=10485760          # 10 MB


# -----------------------------------------------------------------------------
# Outbound webhooks + API keys (consumed by `api` — Wave 3, ADR-0021)
# -----------------------------------------------------------------------------
# Ticket events fan out to a team's active webhook subscriptions: the enqueuer writes a
# pending delivery row, and a background worker signs (HMAC-SHA256) + POSTs it via
# IHttpClientFactory with retry/backoff. WEBHOOKS_ENABLED is the master switch (worker
# returns immediately when false; enqueue still records rows). WEBHOOK_WORKER_POLL_SECONDS
# is the drain tick; WEBHOOK_MAX_ATTEMPTS bounds retries before a delivery is marked failed;
# WEBHOOK_TIMEOUT_SECONDS is the per-attempt HTTP timeout.
WEBHOOKS_ENABLED=true
WEBHOOK_WORKER_POLL_SECONDS=10
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_TIMEOUT_SECONDS=10

# AES-GCM key used to encrypt each subscription's signing secret at rest (the worker must
# re-sign every delivery, so the secret is encrypted — not hashed). REQUIRED in Production
# (the api fails fast on startup if it is missing/empty there, like AUTH_TOKEN_SECRET). In
# Development/Test a built-in dev key is used so local runs + tests need no configuration.
# Generate a strong random value before any real use, e.g.:  openssl rand -base64 48
# DO NOT ship the placeholder. (Prod values are provisioned at deploy, never committed.)
WEBHOOK_SIGNING_KEY=replace-with-a-long-random-secret

# SSRF escape hatch for LOCAL DEV / tests ONLY: when true, http:// subscription URLs are
# accepted AND the send-time private/loopback/link-local IP block is skipped (so you can
# target http://localhost:xxxx). MUST stay false in production (https-only + private-IP
# block defeats SSRF / DNS-rebinding to the compose network or cloud metadata).
WEBHOOKS_ALLOW_INSECURE=false


# -----------------------------------------------------------------------------
# Compose / networking (consumed by docker-compose.yml)
# -----------------------------------------------------------------------------
# Host port that maps to nginx:80 in the `web` container. Open the app at
# http://localhost:${WEB_PORT}. Change this if 8080 is already in use locally.
WEB_PORT=8080
